#!/bin/bash
# Local pre-push CI gate (cargo, node, or mixed repos) — runs the repo's real checks locally at $0
# instead of relying on hosted CI for every push.
#
#   GATE 1 — committed-tree coherence of the tree you are PUSHING (not the working dir), per stack:
#            cargo repos → `cargo metadata`; node repos → package.json parses. Catches the
#            "green locally, garbage in the commit" class. Skipped only if neither manifest exists.
#   GATE 2 — functional gate: runs the pipeline spec at .cigate/gate.json (skip-cached, bounded-parallel).
#
# ENFORCEMENT: if the functional gate cannot RUN (no pipeline-capable runner found), the default is
# fail-OPEN with a LOUD notice — set **GATE_REQUIRE=1** to fail-CLOSED (block the push) so a
# missing runner can never silently let an un-gated push through.
#   BYPASS: `git push --no-verify` (git-native) or `GATE_SKIP=1`.
set -u
# Back-compat: honour the prior env names if the new GATE_* ones are unset.
REQUIRE="${GATE_REQUIRE:-${VERAX_GATE_REQUIRE:-0}}"
[ "${GATE_SKIP:-${VERAX_SKIP_GATE:-0}}" = "1" ] && { echo "[ci-gate] bypassed (GATE_SKIP=1)"; exit 0; }
PUSH_REFS="$(cat 2>/dev/null || true)"   # stdin consumable once — capture before anything reads it
ROOT="$(git rev-parse --show-toplevel 2>/dev/null)" || exit 0

# ---- GATE 1: committed-tree coherence (stack-aware) ----
have_cargo=0; have_node=0
[ -f "$ROOT/Cargo.toml" ] && have_cargo=1
[ -f "$ROOT/package.json" ] && have_node=1
if { [ $have_cargo = 1 ] || [ $have_node = 1 ]; } && command -v tar >/dev/null 2>&1 && [ -n "$PUSH_REFS" ]; then
  ZERO="0000000000000000000000000000000000000000"
  while read -r lref lsha rref rsha; do
    [ -n "${lsha:-}" ] || continue
    [ "$lsha" = "$ZERO" ] && continue
    work="$(mktemp -d 2>/dev/null)" || continue
    if git archive "$lsha" 2>/dev/null | tar -x -C "$work" 2>/dev/null; then
      ok=1
      if [ $have_cargo = 1 ] && command -v cargo >/dev/null 2>&1; then
        ( cd "$work" && cargo metadata --no-deps --format-version 1 >/dev/null 2>&1 ) || ok=0
      fi
      if [ $ok = 1 ] && [ $have_node = 1 ] && command -v node >/dev/null 2>&1; then
        node -e "JSON.parse(require('fs').readFileSync(process.argv[1],'utf8'))" "$work/package.json" >/dev/null 2>&1 || ok=0
      fi
      if [ $ok = 0 ]; then
        rm -rf "$work"
        echo "[ci-gate] GATE 1 FAIL — committed tree $lsha is NOT coherent (manifest missing/unparseable: the corruption class)."
        echo "[ci-gate]   Inspect: git ls-tree -r $lsha | head   ·   Bypass: git push --no-verify"
        exit 1
      fi
    fi
    rm -rf "$work"
  done <<< "$PUSH_REFS"
  echo "[ci-gate] GATE 1: committed-tree coherence OK"
fi

# ---- GATE 2: functional gate via the pipeline runner ----
SPEC="$ROOT/.cigate/gate.json"
[ -f "$SPEC" ] || SPEC="$ROOT/.verax/gate.json"   # back-compat with the prior spec location
[ -f "$SPEC" ] || { echo "[ci-gate] no gate spec — functional gate not configured (push allowed)"; exit 0; }
RUNNER=""
# The pipeline-runner binary (named per the tool that provides it; override with GATE_BIN).
for cand in "${GATE_BIN:-${VERAX_BIN:-}}" "$(command -v verax 2>/dev/null || true)" \
            "/d/dev-cache/.cargo/bin/verax-pipeline.exe" "/d/dev-cache/.cargo/bin/verax.exe" \
            "$ROOT/target/release/verax.exe" "$ROOT/target/debug/verax.exe"; do
  [ -n "$cand" ] || continue
  if "$cand" pipeline --help >/dev/null 2>&1; then RUNNER="$cand"; break; fi
done
if [ -z "$RUNNER" ]; then
  if [ "$REQUIRE" = "1" ]; then
    echo "[ci-gate] BLOCKED — no pipeline-capable runner found and GATE_REQUIRE=1 (strict). The gate could"
    echo "[ci-gate]   not run, so this UN-GATED push is refused. Build/stage the runner, or bypass: git push --no-verify"
    exit 1
  fi
  echo "[ci-gate] ⚠ no pipeline-capable runner found — functional gate did NOT run, push allowed (FAIL-OPEN)."
  echo "[ci-gate]   This push was NOT functionally verified. Set GATE_REQUIRE=1 to enforce (fail-closed)."
  exit 0
fi
echo "[ci-gate] GATE 2: local functional gate ($RUNNER; skip-cached; bypass: git push --no-verify) ..."
if "$RUNNER" pipeline --spec "$SPEC" --cwd "$ROOT"; then
  echo "[ci-gate] PASS — push allowed"; exit 0
fi
echo "[ci-gate] FAIL — push BLOCKED. Fix the gate, or bypass with: git push --no-verify"
exit 1
